{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/manifest.json",
      "dest": "/public/manifest.json"
    },
    {
      "src": "/orion-logo.svg",
      "dest": "/public/orion-logo.svg"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}