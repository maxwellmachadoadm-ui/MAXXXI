{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/weekly-report", "schedule": "0 23 * * 0" },
    { "path": "/api/monitor", "schedule": "0 10 * * *" },
    { "path": "/api/monitor", "schedule": "0 21 * * *" }
  ]
}
